---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy — Klystora" description="Privacy Policy for Klystora.">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8">Privacy Policy</h1>
    <p class="text-sand-500">Last updated: May 2026</p>
    <div class="mt-8 prose prose-sand">
      <p>This page is being prepared. Please check back soon.</p>
    </div>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>

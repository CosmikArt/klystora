---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Abeille Orthographe — Klystora';
const description = 'Formez des mots avec 7 lettres. Doit utiliser la lettre centrale. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Abeille Orthographe</h1>
      <p class="text-sand-500 mt-1">Formez des mots avec 7 lettres. Doit utiliser la lettre centrale</p>
    </div>
    
    <LazyGameWrapper game="spelling-bee" lang="fr" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
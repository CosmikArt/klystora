---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Former Mots — Klystora';
const description = 'Formez des mots avec 7 lettres. Free daily puzzle in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Former Mots</h1>
      <p class="text-sand-500 mt-1">Formez des mots avec 7 lettres</p>
    </div>
    
    <LazyGameWrapper game="word-scramble" lang="fr" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">Comment Jouer à Former Mots</h2>
      <p class="text-sand-500 mb-4">Former Mots vous défie de former autant de mots que possible avec 7 lettres. La lettre centrale doit être utilisée dans chaque mot.</p>
      <ul class="space-y-2 mb-6">
        <li>Les mots doivent avoir au moins 3 lettres</li>
        <li>Chaque mot doit inclure la lettre centrale</li>
        <li>Les lettres peuvent être utilisées plusieurs fois</li>
        <li>3 lettres = 100pts, 4 = 200pts, 5 = 400pts, 6 = 800pts, 7+ = 1500pts</li>
        <li>Trouvez un pangramme (utilise les 7 lettres) pour un bonus 2x</li>
      </ul>
      <p class="text-sand-500">Nouveau puzzle à chaque partie. Relevez le défi d atteindre le rang Queen Bee!</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
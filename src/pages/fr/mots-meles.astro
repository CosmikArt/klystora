---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Mots Mêlés — Klystora';
const description = 'Trouvez tous les mots cachés dans la grille. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Mots Mêlés</h1>
      <p class="text-sand-500 mt-1">Trouvez tous les mots cachés dans la grille</p>
    </div>
    
    <LazyGameWrapper game="word-search" lang="fr" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
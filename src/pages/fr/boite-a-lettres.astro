---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Boîte à Lettres — Klystora';
const description = 'Connectez des lettres de côtés différents pour former des mots. Free puzzle in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Boîte à Lettres</h1>
      <p class="text-sand-500 mt-1">Connectez des lettres de côtés différents pour former des mots</p>
    </div>
    
    <LazyGameWrapper game="letter-boxed" lang="fr" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
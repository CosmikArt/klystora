---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const blogDir = path.resolve(process.cwd(), 'src/content/blog');
  const files = fs.readdirSync(blogDir).filter(f => f.endsWith('.md'));
  
  return files.map(filename => {
    const slug = filename.replace('.md', '');
    const filePath = path.join(blogDir, filename);
    const content = fs.readFileSync(filePath, 'utf-8');
    const { data } = matter(content);
    return {
      params: { slug },
      props: { frontmatter: data, content }
    };
  });
}

const { frontmatter, content } = Astro.props;
const title = frontmatter.title || 'Untitled';
const description = frontmatter.description || '';
const date = new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tags = frontmatter.tags || [];
---

<Layout title={`${title} — Klystora Blog`} description={description}>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map(tag => (
        <span class="text-xs px-2 py-1 rounded-full bg-violet-900/30 text-violet-300">{tag}</span>
      ))}
    </div>
    <h1 class="text-4xl font-bold mb-4">{title}</h1>
    <time class="text-sm text-sand-600 mb-8 block">{date}</time>
    <div class="prose prose-invert prose-sand max-w-none">
      <p class="text-sand-400">{description}</p>
    </div>
    <div class="mt-12 pt-8 border-t border-sand-800">
      <a href="/blog" class="text-coral-400 hover:text-coral-300">← Back to Blog</a>
    </div>
  </article>
  <PwaInstallPrompt client:only="react" />
</Layout>
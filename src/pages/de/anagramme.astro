---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Anagramme — Klystora';
const description = 'Bilden Sie Wörter aus 7 Buchstaben in 2 Minuten. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Anagramme</h1>
      <p class="text-sand-500 mt-1">Bilden Sie Wörter aus 7 Buchstaben in 2 Minuten</p>
    </div>
    
    <LazyGameWrapper game="anagrams" lang="de" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Kreuzworträtsel — Klystora';
const description = 'Füllen Sie das Raster mit Wörtern, die zu den Hinweisen passen. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Kreuzworträtsel</h1>
      <p class="text-sand-500 mt-1">Füllen Sie das Raster mit Wörtern, die zu den Hinweisen passen</p>
    </div>
    
    <LazyGameWrapper game="crossword" lang="de" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
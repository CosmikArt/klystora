---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Wörter Bilden — Klystora';
const description = 'Bilde Wörter aus 7 Buchstaben. Free daily puzzle in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Wörter Bilden</h1>
      <p class="text-sand-500 mt-1">Bilde Wörter aus 7 Buchstaben</p>
    </div>
    
    <LazyGameWrapper game="word-scramble" lang="de" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">Wie man Wörter Bilden spielt</h2>
      <p class="text-sand-500 mb-4">Wörter Bilden fordert dich heraus, aus 7 Buchstaben so viele Wörter wie möglich zu bilden. Der Mittelbuchstabe muss in jedem Wort verwendet werden.</p>
      <ul class="space-y-2 mb-6">
        <li>Wörter müssen mindestens 3 Buchstaben lang sein</li>
        <li>Jedes Wort muss den Mittelbuchstaben enthalten</li>
        <li>Buchstaben können mehrfach verwendet werden</li>
        <li>3 Buchstaben = 100pts, 4 = 200pts, 5 = 400pts, 6 = 800pts, 7+ = 1500pts</li>
        <li>Finde ein Pangramm (verwendet alle 7 Buchstaben) für 2x Bonus</li>
      </ul>
      <p class="text-sand-500">Bei jedem Spiel ein neues Puzzle. Fordere dich heraus, den Queen Bee-Rang zu erreichen!</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
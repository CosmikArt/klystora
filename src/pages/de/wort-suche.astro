---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Wort-Suche — Klystora';
const description = 'Finde alle versteckten Wörter im Raster. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Wort-Suche</h1>
      <p class="text-sand-500 mt-1">Finde alle versteckten Wörter im Raster</p>
    </div>
    
    <LazyGameWrapper game="word-search" lang="de" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
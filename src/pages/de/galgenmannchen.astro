---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Galgenmännchen — Klystora';
const description = 'Errate das versteckte Wort Buchstabe für Buchstabe. Du hast 6 Leben. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Galgenmännchen</h1>
      <p class="text-sand-500 mt-1">Errate das versteckte Wort Buchstabe für Buchstabe. Du hast 6 Leben</p>
    </div>
    
    <LazyGameWrapper game="hangman" lang="de" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
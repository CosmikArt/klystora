---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = "Tipprace — Teste deine Geschwindigkeit | Klystora";
const description = "Kostenloser Tipptest. Messe deine WPM und Genauigkeit in 27 Sprachen. Keine Anmeldung.";
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Tipprace</h1>
      <p class="text-sand-500 mt-1">Teste deine Tippgeschwindigkeit und Genauigkeit</p>
    </div>
    
    <LazyGameWrapper game="typing-race" lang="de" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">Wie man Tipprace spielt</h2>
      <p class="text-sand-500 mb-4">Tipprace misst deine Tippgeschwindigkeit in Wörtern pro Minute (WPM) und Genauigkeit. Tippe den angezeigten Text so schnell und genau wie möglich.</p>
      <ul class="space-y-2 mb-6">
        <li>Wähle dein Zeitlimit: 30, 60 oder 120 Sekunden</li>
        <li>Tippe den Text genau wie angezeigt</li>
        <li>Richtige Zeichen werden grün, Fehler rot</li>
        <li>Deine WPM und Genauigkeit werden in Echtzeit berechnet</li>
        <li>Schlage deinen persönlichen Rekord und steige auf</li>
      </ul>
      <p class="text-sand-500">Übe täglich, um deine Geschwindigkeit zu verbessern. Der Durchschnitt liegt bei 40 WPM, Profis erreichen 80+ WPM.</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Anagrams — Klystora';
const description = 'Form words from 7 letters in 2 minutes. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Anagrams</h1>
      <p class="text-sand-500 mt-1">Form words from 7 letters in 2 minutes. How many can you find?</p>
    </div>
    
    <LazyGameWrapper game="anagrams" lang="uk" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
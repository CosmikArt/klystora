---
import Layout from '../layouts/Layout.astro';
import WordLadderWrapper from '../components/games/wordladder/WordLadderWrapper';

const title = 'Word Ladder — Klystora';
const description = 'Transform one word into another by changing one letter at a time. A new puzzle every day.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <WordLadderWrapper lang="en" client:only="react" />

    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Play Word Ladder</h2>
      <p class="text-sand-500 mb-4">Transform the starting word into the target word by changing one letter at a time.</p>
      <ul class="space-y-2 mb-6">
        <li><strong style="color:#4A8B5B">Change</strong> — exactly one letter per step</li>
        <li><strong style="color:#D9A93E">Valid</strong> — each step must be a real word</li>
        <li><strong style="color:#6845BC">Shortest</strong> — path wins the most points</li>
      </ul>
      <p class="text-sand-500">Find the shortest path between the two words!</p>
    </article>
    <section class="mt-12">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
        <details class="mb-3">
          <summary class="font-medium cursor-pointer">Can I reuse words?</summary>
          <p class="text-sand-500 mt-2">No, each word in the chain must be unique.</p>
        </details>
        <details class="mb-3">
          <summary class="font-medium cursor-pointer">What if I get stuck?</summary>
          <p class="text-sand-500 mt-2">Use a hint to reveal the next word in the optimal path.</p>
        </details>
    </section>
  </div>
</Layout>
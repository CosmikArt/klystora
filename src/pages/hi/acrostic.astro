---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'एक्रोस्टिक — Klystora';
const description = 'सुरागों को हल करें। प्रत्येक उत्तर के पहले अक्षर छिपे शब्द को प्रकट करते हैं!. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">एक्रोस्टिक</h1>
      <p class="text-sand-500 mt-1">सुरागों को हल करें। प्रत्येक उत्तर के पहले अक्षर छिपे शब्द को प्रकट करते हैं!</p>
    </div>
    
    <LazyGameWrapper game="acrostic" lang="hi" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
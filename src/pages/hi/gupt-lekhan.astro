---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'गुप्तलेखन — Klystora';
const description = 'सिफर तोड़ें और छिपी उद्धरण प्रकट करें. Free daily puzzle in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">गुप्तलेखन</h1>
      <p class="text-sand-500 mt-1">सिफर तोड़ें और छिपी उद्धरण प्रकट करें</p>
    </div>
    
    <LazyGameWrapper game="cryptogram" lang="hi" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
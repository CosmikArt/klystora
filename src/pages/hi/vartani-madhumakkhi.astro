---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'वर्तनी मधुमक्खी — Klystora';
const description = '7 अक्षरों से शब्द बनाएं। केंद्र अक्षर का उपयोग अनिवार्य. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">वर्तनी मधुमक्खी</h1>
      <p class="text-sand-500 mt-1">7 अक्षरों से शब्द बनाएं। केंद्र अक्षर का उपयोग अनिवार्य</p>
    </div>
    
    <LazyGameWrapper game="spelling-bee" lang="hi" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
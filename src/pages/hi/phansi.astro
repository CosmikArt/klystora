---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'फांसी — Klystora';
const description = 'एक-एक अक्षर करके छिपे शब्द का अनुमान लगाएं। आपके पास 6 जीवन हैं. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">फांसी</h1>
      <p class="text-sand-500 mt-1">एक-एक अक्षर करके छिपे शब्द का अनुमान लगाएं। आपके पास 6 जीवन हैं</p>
    </div>
    
    <LazyGameWrapper game="hangman" lang="hi" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
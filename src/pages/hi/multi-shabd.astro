---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'मल्टी-शब्द — Klystora';
const description = 'एक साथ कई Wordle बोर्ड हल करें. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">मल्टी-शब्द</h1>
      <p class="text-sand-500 mt-1">एक साथ कई Wordle बोर्ड हल करें</p>
    </div>
    
    <LazyGameWrapper game="multi-wordle" lang="hi" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
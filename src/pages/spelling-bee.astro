---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
import LazyGameWrapper from '../components/games/LazyGameWrapper';

const title = 'Spelling Bee — NYT-Style Word Game | Klystora';
const description = 'Form words using 7 letters. Must use the center letter. Find pangrams for bonus points. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={{title}} description={{description}} ogImage={{ogImage}}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Spelling Bee</h1>
      <p class="text-sand-500 mt-1">Form words with 7 letters. Must use the center letter. Find pangrams for bonus points!</p>
    </div>
    
    <LazyGameWrapper game="spelling-bee" lang="en" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Play Spelling Bee</h2>
      <p class="text-sand-500 mb-4">Spelling Bee is a word puzzle where you form as many words as possible using 7 letters, with one letter required in every word.</p>
      <ul class="space-y-2 mb-6">
        <li>Words must be at least 4 letters long</li>
        <li>Every word must include the center letter</li>
        <li>Letters can be used multiple times</li>
        <li>4-letter words = 1 point, longer words = more points</li>
        <li>Pangrams (use all 7 letters) = word length + 7 bonus points</li>
      </ul>
      <p class="text-sand-500">Inspired by the NYT puzzle, Spelling Bee tests your vocabulary and creativity. Can you reach Queen Bee rank?</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
---
// Redirect to browser language or default to English
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLang = acceptLang.split(',')[0]?.split('-')[0]?.toLowerCase() || 'en';

const supportedLangs = ['en', 'es', 'zh', 'hi', 'pt', 'bn', 'ru', 'ja', 'de', 'ko', 'fr', 'tr', 'it', 'pl', 'nl', 'uk', 'ro', 'el', 'cs', 'sv', 'hu', 'id', 'vi', 'th', 'da', 'fi', 'no'];
const targetLang = supportedLangs.includes(browserLang) ? browserLang : 'en';

return Astro.redirect(targetLang === 'en' ? '/' : `/${targetLang}/`);
---

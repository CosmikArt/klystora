---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
import LazyGameWrapper from '../components/games/LazyGameWrapper';

const title = 'Word Search — Find Hidden Words | Klystora';
const description = 'Classic word search puzzle. Find all hidden words in the letter grid. Click and drag to select. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={{title}} description={{description}} ogImage={{ogImage}}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Word Search</h1>
      <p class="text-sand-500 mt-1">Find all hidden words in the grid. Click and drag to select!</p>
    </div>
    
    <LazyGameWrapper game="word-search" lang="en" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Play Word Search</h2>
      <p class="text-sand-500 mb-4">Word Search is a classic puzzle where words are hidden in a grid of letters. Words can be placed horizontally, vertically, or diagonally in any direction.</p>
      <ul class="space-y-2 mb-6">
        <li>Look at the word list below the grid</li>
        <li>Click and drag across letters to form a word</li>
        <li>Words can go in any direction: horizontal, vertical, diagonal</li>
        <li>Find all words to complete the puzzle</li>
        <li>Race against the clock for the best time!</li>
      </ul>
      <p class="text-sand-500">Word Search puzzles improve visual scanning and pattern recognition skills. They're fun for all ages!</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import { getMessages, getGameUrl, locales, type Locale } from '../../lib/i18n';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
const messages = getMessages(locale as Locale);

const games = [
  { key: 'dailyWord', img: '/game-daily-word-preview.png' },
  { key: 'crossword', img: '/game-crossword-preview.png' },
  { key: 'wordSearch', img: '/game-word-search-preview.png' },
  { key: 'anagrams', img: '/game-anagrams-preview.png' },
  { key: 'connections', img: '/game-connections-preview.png' },
  { key: 'spellingBee', img: '/game-spelling-bee-preview.png' },
  { key: 'wordLadder', img: '/game-word-ladder-preview.png' },
  { key: 'rosco', img: '/game-rosco-preview.png' },
  { key: 'sudoku', img: '/game-sudoku-preview.png' },
  { key: 'memory', img: '/game-memory-preview.png' },
  { key: 'hangman', img: '/game-hangman-preview.png' },
  { key: 'trivia', img: '/game-trivia-preview.png' },
  { key: 'game2048', img: '/game-2048-preview.png' },
  { key: 'minesweeper', img: '/game-minesweeper-preview.png' },
] as const;
---

<Layout title={`Klystora — ${messages.tagline}`} description={messages.subtitle}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-28">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-coal leading-tight mb-6">
          {messages.tagline}
        </h1>
        <p class="text-lg md:text-xl text-sand-500 mb-8 leading-relaxed">
          {messages.subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={getGameUrl('dailyWord', locale as Locale)} class="bg-violet-500 text-white font-medium px-8 py-3 rounded-xl hover:bg-violet-600 transition shadow-violet">
            {messages.playNow}
          </a>
          <a href="#games" class="border-2 border-violet-500 text-violet-500 font-medium px-8 py-3 rounded-xl hover:bg-violet-50 transition">
            {messages.exploreGames}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Games Grid -->
  <section id="games" class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-center mb-12">14 Ways to Play</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {games.map((game, idx) => (
        <a 
          href={getGameUrl(game.key, locale as Locale)} 
          class="group block bg-white border border-sand-200 rounded-2xl overflow-hidden hover:shadow-lg hover:border-violet-300 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 transition-all"
          tabindex="0"
          aria-label={`Play ${messages.games[game.key].name}: ${messages.games[game.key].desc}`}
        >
          <div class="aspect-[4/3] bg-sand-100 overflow-hidden relative">
            <img src={game.img} alt={messages.games[game.key].name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
            <div class="absolute inset-0 bg-violet-500/0 group-hover:bg-violet-500/10 group-focus:bg-violet-500/20 transition-colors" />
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-coal group-hover:text-violet-500 group-focus:text-violet-600 transition">{messages.games[game.key].name}</h3>
            <p class="text-sm text-sand-500 mt-1">{messages.games[game.key].desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Value Props -->
  <section class="bg-violet-50 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">27 Languages</h3>
          <p class="text-sm text-sand-500">Native vocabulary in each. Not translated. Curated.</p>
        </div>
        <div>
          <div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">Instant Play</h3>
          <p class="text-sm text-sand-500">No signup. No app download. No waiting. Just play.</p>
        </div>
        <div>
          <div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">Privacy First</h3>
          <p class="text-sm text-sand-500">No tracking. No third-party cookies. Your data stays yours.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

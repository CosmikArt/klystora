---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Archive — Klystora" description="Browse past puzzles. Coming soon.">
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <div class="mb-8">
      <svg class="w-20 h-20 mx-auto text-violet-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
      </svg>
      <h1 class="text-4xl font-bold mb-4">Puzzle Archive</h1>
      <p class="text-sand-500 text-lg mb-2">Browse and replay past puzzles.</p>
      <p class="text-sand-400 text-sm">Every Daily Word, Crossword, and more — searchable by date.</p>
    </div>

    <div class="bg-sand-100 dark:bg-sand-900 rounded-2xl p-8 mb-8">
      <h2 class="text-xl font-semibold mb-4">Coming in Q3 2026</h2>
      <ul class="text-left space-y-3 mb-6 max-w-md mx-auto">
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Calendar view of all past puzzles</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Search by date or puzzle number</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Filter by difficulty or game type</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Share specific puzzles with friends</span>
        </li>
      </ul>
      <p class="text-sand-500 text-sm">Free for Pro subscribers. Included with your $4/month plan.</p>
    </div>

    <a href="/pricing" class="inline-block bg-violet-600 text-white font-medium px-6 py-3 rounded-lg hover:bg-violet-700 transition">
      View Pricing
    </a>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>

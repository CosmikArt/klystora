---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
import LazyGameWrapper from '../components/games/LazyGameWrapper';

const title = 'Acrostic — Hidden Word Puzzle | Klystora';
const description = 'Solve clues to reveal a hidden word formed by the first letters of each answer. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={{title}} description={{description}} ogImage={{ogImage}}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Acrostic</h1>
      <p class="text-sand-500 mt-1">Solve the clues. The first letters of each answer reveal a hidden word!</p>
    </div>
    
    <LazyGameWrapper game="acrostic" lang="en" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Solve Acrostics</h2>
      <p class="text-sand-500 mb-4">An acrostic is a word puzzle where the first letters of each answer spell out a hidden word or message.</p>
      <ul class="space-y-2 mb-6">
        <li>Read each clue and type your answer</li>
        <li>The first letter of each answer goes into the hidden word display</li>
        <li>Use hints if you get stuck — they reveal one letter at a time</li>
        <li>When all answers are correct, the hidden word is revealed</li>
      </ul>
      <p class="text-sand-500">Acrostics combine vocabulary, trivia knowledge, and pattern recognition into one satisfying puzzle.</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
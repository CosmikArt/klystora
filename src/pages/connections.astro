---
import Layout from '../layouts/Layout.astro';

const title = 'Connections — Klystora';
const description = 'Group 16 words into 4 categories.';
---

<Layout title={title} description={description}>
  <div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl font-bold mb-4">Connections</h1>
    <p class="text-lg text-sand-500 mb-8">Group 16 words into 4 categories.</p>
    <div class="bg-violet-50 rounded-2xl p-8">
      <p class="text-violet-600 font-medium">Coming soon — we're building this game!</p>
      <p class="text-sand-500 text-sm mt-2">Play <a href="/daily-word" class="text-violet-500 underline">Daily Word</a> while you wait.</p>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import ConnectionsWrapper from '../components/games/connections/ConnectionsWrapper';

const title = 'Connections — Klystora';
const description = 'Find groups of 4 words that share a common theme. A new puzzle every day.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <ConnectionsWrapper client:only="react" />
  </div>
</Layout>
---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Виселица — Klystora';
const description = 'Угадывайте скрытое слово по буквам. У вас 6 жизней. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Виселица</h1>
      <p class="text-sand-500 mt-1">Угадывайте скрытое слово по буквам. У вас 6 жизней</p>
    </div>
    
    <LazyGameWrapper game="hangman" lang="ru" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
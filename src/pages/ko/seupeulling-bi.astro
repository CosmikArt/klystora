---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = '스펠링 비 — Klystora';
const description = '7글자로 단어를 만드세요. 가울데 글자 필수. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">스펠링 비</h1>
      <p class="text-sand-500 mt-1">7글자로 단어를 만드세요. 가울데 글자 필수</p>
    </div>
    
    <LazyGameWrapper game="spelling-bee" lang="ko" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
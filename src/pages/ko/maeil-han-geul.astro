---
import Layout from '../../layouts/Layout.astro';
import DailyWordWrapper from '../../components/games/DailyWordWrapper';
import { getMessages, type Locale } from '../../lib/i18n';

const locale: Locale = 'ko';
const messages = getMessages(locale);
const gameInfo = messages.games.dailyWord;
---

<Layout title={`${gameInfo.name} — Klystora`} description={gameInfo.desc}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">{gameInfo.name}</h1>
      <p class="text-sand-500 mt-1">{gameInfo.desc}</p>
    </div>
    <DailyWordWrapper client:only="react" />
  </div>
</Layout>

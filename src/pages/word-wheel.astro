---
import Layout from '../layouts/Layout.astro';
import RoscoWrapper from '../components/games/rosco/RoscoWrapper';

const title = 'Word Wheel — Klystora';
const description = 'Find words for each letter of the alphabet. A new puzzle every day.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <RoscoWrapper client:only="react" />
  </div>
</Layout>
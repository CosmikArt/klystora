---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Practice Mode — Klystora" description="Unlimited practice puzzles. Coming soon.">
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <div class="mb-8">
      <svg class="w-20 h-20 mx-auto text-violet-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
      </svg>
      <h1 class="text-4xl font-bold mb-4">Practice Mode</h1>
      <p class="text-sand-500 text-lg mb-2">Unlimited puzzles. No daily limit.</p>
      <p class="text-sand-400 text-sm">Replay any difficulty, any game, any time.</p>
    </div>

    <div class="bg-sand-100 dark:bg-sand-900 rounded-2xl p-8 mb-8">
      <h2 class="text-xl font-semibold mb-4">Coming in Q3 2026</h2>
      <ul class="text-left space-y-3 mb-6 max-w-md mx-auto">
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Unlimited Daily Word puzzles</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Custom difficulty for Crosswords</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Timed challenges for all games</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm">Practice specific letter combinations</span>
        </li>
      </ul>
      <p class="text-sand-500 text-sm">Free for Pro subscribers. Included with your $4/month plan.</p>
    </div>

    <a href="/pricing" class="inline-block bg-violet-600 text-white font-medium px-6 py-3 rounded-lg hover:bg-violet-700 transition">
      View Pricing
    </a>
  </div>
</Layout>

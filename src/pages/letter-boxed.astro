---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
import LazyGameWrapper from '../components/games/LazyGameWrapper';

const title = 'Letter Boxed — Connect Letters | Klystora';
const description = 'NYT-style Letter Boxed puzzle. Connect letters from different sides to form words. Use all 12 letters to win. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={{title}} description={{description}} ogImage={{ogImage}}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Letter Boxed</h1>
      <p class="text-sand-500 mt-1">Connect letters from different sides to form words. Use all 12 letters to win!</p>
    </div>
    
    <LazyGameWrapper game="letter-boxed" lang="en" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Play Letter Boxed</h2>
      <p class="text-sand-500 mb-4">Letter Boxed is a word puzzle where you connect letters from the sides of a square to form valid words.</p>
      <ul class="space-y-2 mb-6">
        <li>Click letters from different sides to form words</li>
        <li>Consecutive letters must come from different sides</li>
        <li>Words must be at least 3 letters long</li>
        <li>Use all 12 letters to achieve Queen Bee rank</li>
        <li>Longer words score more points</li>
      </ul>
      <p class="text-sand-500">Inspired by the NYT puzzle, Letter Boxed tests your vocabulary and spatial thinking. Can you find the perfect chain of words?</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Klystora" description="Learn about Klystora, the daily word game destination.">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8">About Klystora</h1>
    <p class="text-lg text-sand-500 mb-6">Klystora is a daily word game suite built for people who love word puzzles. Eight games, 30 languages, zero signup required.</p>
    <p class="text-sand-500">Built by Ore Data México S.A.</p>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>

---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Ahorcado — Klystora';
const description = 'Adivina la palabra oculta letra por letra. ¡No dejes que se complete el ahorcado!';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Ahorcado</h1>
      <p class="text-sand-500 mt-1">Adivina la palabra antes de que sea tarde</p>
    </div>
    
    <LazyGameWrapper game="hangman" lang="es" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">Cómo Jugar Ahorcado</h2>
      <p class="text-sand-500 mb-4">Ahorcado es un juego de adivinanza de palabras donde intentas descubrir una palabra oculta sugiriendo letras una a la vez.</p>
      <ul class="space-y-2 mb-6">
        <li>Adivina letras usando el teclado en pantalla o tu teclado físico</li>
        <li>Las letras correctas se revelan en la palabra</li>
        <li>Las letras incorrectas agregan una parte al dibujo del ahorcado</li>
        <li>Tienes 6 errores antes de que termine el juego</li>
      </ul>
      <p class="text-sand-500">¿Puedes adivinar la palabra antes de que se complete el ahorcado?</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
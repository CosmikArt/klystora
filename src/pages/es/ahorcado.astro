---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Ahorcado — Klystora';
const description = 'Adivina la palabra oculta letra por letra. Tienes 6 vidas. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Ahorcado</h1>
      <p class="text-sand-500 mt-1">Adivina la palabra oculta letra por letra. Tienes 6 vidas</p>
    </div>
    
    <LazyGameWrapper game="hangman" lang="es" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Criptograma — Klystora';
const description = 'Descifra el código y revela la cita oculta. Free daily puzzle in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Criptograma</h1>
      <p class="text-sand-500 mt-1">Descifra el código y revela la cita oculta</p>
    </div>
    
    <LazyGameWrapper game="cryptogram" lang="es" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
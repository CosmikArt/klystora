---
import Layout from '../../layouts/Layout.astro';
import SpellingBeeWrapper from '../../components/games/spellingbee/SpellingBeeWrapper';

const title = 'Colmena — Klystora';
const description = 'Forma palabras usando 7 letras. Un nuevo puzzle cada día.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <SpellingBeeWrapper client:only="react" />
  </div>
</Layout>
---
import Layout from '../../layouts/Layout.astro';

const title = 'Colmena — Klystora';
const description = 'Forma palabras usando 7 letras.';
---

<Layout title={title} description={description}>
  <div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl font-bold mb-4">Colmena</h1>
    <p class="text-lg text-sand-500 mb-8">Forma palabras usando 7 letras.</p>
    <div class="bg-violet-50 rounded-2xl p-8">
      <p class="text-violet-600 font-medium">Próximamente — ¡estamos construyendo este juego!</p>
      <p class="text-sand-500 text-sm mt-2">Juega <a href="/es/palabra-diaria" class="text-violet-500 underline">Palabra Diaria</a> mientras tanto.</p>
    </div>
  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import WordSearchWrapper from '../../components/games/wordsearch/WordSearchWrapper';

const title = 'Sopa de Letras — Klystora';
const description = 'Encuentra palabras ocultas en la cuadrícula. Un nuevo puzzle cada día.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <WordSearchWrapper client:only="react" />
  </div>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import CrosswordWrapper from '../../components/games/crossword/CrosswordWrapper';

const title = 'Crucigrama Mini — Klystora';
const description = 'Resuelve la cuadrícula de crucigrama 5×5. Un nuevo puzzle cada día.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <CrosswordWrapper client:only="react" />
  </div>
</Layout>
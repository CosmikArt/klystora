---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nosotros — Klystora" description="Conoce Klystora, tu destino de juegos de palabras diarios.">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8">Sobre Klystora</h1>
    <p class="text-lg text-sand-500 mb-6">Klystora es una suite de juegos de palabras diarios para personas que aman los puzzles. Ocho juegos, 30 idiomas, sin registro.</p>
    <p class="text-sand-500">Construido por Ore Data México S.A.</p>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import WordLadderWrapper from '../../components/games/wordladder/WordLadderWrapper';

const title = 'Escalera de Palabras — Klystora';
const description = 'Transforma una palabra en otra cambiando una letra a la vez. Un nuevo puzzle cada día.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <WordLadderWrapper client:only="react" />
  </div>
</Layout>
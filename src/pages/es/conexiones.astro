---
import Layout from '../../layouts/Layout.astro';
import ConnectionsWrapper from '../../components/games/connections/ConnectionsWrapper';

const title = 'Conexiones — Klystora';
const description = 'Encuentra grupos de 4 palabras que comparten un tema. Un nuevo puzzle cada día.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <ConnectionsWrapper client:only="react" />
  </div>
</Layout>
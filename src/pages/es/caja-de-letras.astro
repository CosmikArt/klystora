---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Caja de Letras — Klystora';
const description = 'Conecta letras de diferentes lados para formar palabras. Free puzzle in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Caja de Letras</h1>
      <p class="text-sand-500 mt-1">Conecta letras de diferentes lados para formar palabras</p>
    </div>
    
    <LazyGameWrapper game="letter-boxed" lang="es" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
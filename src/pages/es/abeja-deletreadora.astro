---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Abeja Deletreadora — Klystora';
const description = 'Forma palabras con 7 letras. Debes usar la letra del centro. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Abeja Deletreadora</h1>
      <p class="text-sand-500 mt-1">Forma palabras con 7 letras. Debes usar la letra del centro</p>
    </div>
    
    <LazyGameWrapper game="spelling-bee" lang="es" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
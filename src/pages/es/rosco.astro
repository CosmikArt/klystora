---
import Layout from '../../layouts/Layout.astro';
import RoscoWrapper from '../../components/games/rosco/RoscoWrapper';

const title = 'Rosco — Klystora';
const description = 'Encuentra palabras para cada letra del abecedario. Un nuevo puzzle cada día.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <RoscoWrapper client:only="react" />
  </div>
</Layout>
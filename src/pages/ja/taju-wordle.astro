---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'マルチワードル — Klystora';
const description = '複数のWordleボードを同時に解く. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">マルチワードル</h1>
      <p class="text-sand-500 mt-1">複数のWordleボードを同時に解く</p>
    </div>
    
    <LazyGameWrapper game="multi-wordle" lang="ja" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
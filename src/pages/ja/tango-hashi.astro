---
import Layout from '../../layouts/Layout.astro';
import WordLadderWrapper from '../../components/games/wordladder/WordLadderWrapper';
import { getMessages, type Locale } from '../../lib/i18n';

const locale: Locale = 'ja';
const messages = getMessages(locale);
const gameInfo = messages.games.wordLadder;
---

<Layout title={`${gameInfo.name} — Klystora`} description={gameInfo.desc}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">{gameInfo.name}</h1>
      <p class="text-sand-500 mt-1">{gameInfo.desc}</p>
    </div>
    <WordLadderWrapper lang="ja" client:only="react" />
  </div>
</Layout>

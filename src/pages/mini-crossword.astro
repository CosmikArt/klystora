---
import Layout from '../layouts/Layout.astro';
import CrosswordWrapper from '../components/games/crossword/CrosswordWrapper';

const title = 'Crossword Mini — Klystora';
const description = 'Solve the 5×5 crossword grid. A new puzzle every day.';
---

<Layout title={title} description={description}>
  <div class="min-h-[calc(100vh-200px)] flex flex-col items-center justify-start pt-8 px-4">
    <CrosswordWrapper client:only="react" />
  </div>
</Layout>
---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
import LazyGameWrapper from '../components/games/LazyGameWrapper';

const title = 'Anagrams — Race Against the Clock | Klystora';
const description = 'Form as many words as possible from 7 letters in 2 minutes. Test your vocabulary speed. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={{title}} description={{description}} ogImage={{ogImage}}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Anagrams</h1>
      <p class="text-sand-500 mt-1">Form words from 7 letters in 2 minutes. How many can you find?</p>
    </div>
    
    <LazyGameWrapper game="anagrams" lang="en" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Play Anagrams</h2>
      <p class="text-sand-500 mb-4">Anagrams is a fast-paced word game where you race against the clock to form as many words as possible from a set of letters.</p>
      <ul class="space-y-2 mb-6">
        <li>You have 2 minutes to find words</li>
        <li>Words must be at least 3 letters long</li>
        <li>Click letters to form a word, then press Enter</li>
        <li>Each letter can only be used once per word</li>
        <li>Longer words score more points</li>
      </ul>
      <p class="text-sand-500">Anagrams tests your vocabulary speed and pattern recognition. Great for quick brain training!</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
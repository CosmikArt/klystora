---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../layouts/Layout.astro';
import LazyGameWrapper from '../components/games/LazyGameWrapper';

const title = 'Hangman — Classic Word Game | Klystora';
const description = 'Guess the hidden word letter by letter. Classic hangman word game. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={{title}} description={{description}} ogImage={{ogImage}}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Hangman</h1>
      <p class="text-sand-500 mt-1">Guess the hidden word letter by letter. You have 6 lives.</p>
    </div>
    
    <LazyGameWrapper game="hangman" lang="en" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">How to Play Hangman</h2>
      <p class="text-sand-500 mb-4">Hangman is a classic word guessing game that has been played for centuries.</p>
      <ul class="space-y-2 mb-6">
        <li>A word is chosen at random</li>
        <li>Guess one letter at a time</li>
        <li>Correct guesses reveal the letter</li>
        <li>Wrong guesses cost a life (6 total)</li>
        <li>Guess the word before you run out of lives</li>
      </ul>
      <p class="text-sand-500">Hangman is perfect for vocabulary building and pattern recognition. A timeless classic!</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
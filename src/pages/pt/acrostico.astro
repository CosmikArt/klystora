---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Acróstico — Klystora';
const description = 'Resolva as pistas. As primeiras letras revelam uma palavra oculta!. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Acróstico</h1>
      <p class="text-sand-500 mt-1">Resolva as pistas. As primeiras letras revelam uma palavra oculta!</p>
    </div>
    
    <LazyGameWrapper game="acrostic" lang="pt" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
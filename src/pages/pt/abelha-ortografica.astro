---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Abelha Ortográfica — Klystora';
const description = 'Forme palavras com 7 letras. Deve usar a letra do centro. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Abelha Ortográfica</h1>
      <p class="text-sand-500 mt-1">Forme palavras com 7 letras. Deve usar a letra do centro</p>
    </div>
    
    <LazyGameWrapper game="spelling-bee" lang="pt" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
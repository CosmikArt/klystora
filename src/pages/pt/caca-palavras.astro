---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Caça-Palavras — Klystora';
const description = 'Encontre todas as palavras ocultas na grade. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Caça-Palavras</h1>
      <p class="text-sand-500 mt-1">Encontre todas as palavras ocultas na grade</p>
    </div>
    
    <LazyGameWrapper game="word-search" lang="pt" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
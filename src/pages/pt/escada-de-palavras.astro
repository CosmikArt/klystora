---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = 'Escada de Palavras — Klystora';
const description = 'Mude uma letra de cada vez para chegar à palavra alvo. Free in 27 languages.';
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Escada de Palavras</h1>
      <p class="text-sand-500 mt-1">Mude uma letra de cada vez para chegar à palavra alvo</p>
    </div>
    
    <LazyGameWrapper game="word-ladder" lang="pt" client:only="react" />
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
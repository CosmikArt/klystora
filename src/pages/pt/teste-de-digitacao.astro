---
import PwaInstallPrompt from '@/components/PwaInstallPrompt';
import Layout from '../../layouts/Layout.astro';
import LazyGameWrapper from '../../components/games/LazyGameWrapper';

const title = "Corrida de Digitação — Teste sua Velocidade | Klystora";
const description = "Teste de velocidade de digitação gratuito. Meça seu PPM e precisão em 27 idiomas. Sem cadastro.";
const ogImage = '/og/default.jpg';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-bold">Corrida de Digitação</h1>
      <p class="text-sand-500 mt-1">Teste sua velocidade e precisão de digitação</p>
    </div>
    
    <LazyGameWrapper game="typing-race" lang="pt" client:only="react" />
    
    <article class="mt-16 max-w-none">
      <h2 class="text-2xl font-bold mb-4">Como Jogar Corrida de Digitação</h2>
      <p class="text-sand-500 mb-4">Corrida de Digitação mede sua velocidade em palavras por minuto (PPM) e precisão. Digite o texto exibido o mais rápido e precisamente possível.</p>
      <ul class="space-y-2 mb-6">
        <li>Escolha seu limite de tempo: 30, 60 ou 120 segundos</li>
        <li>Digite o texto exatamente como mostrado</li>
        <li>Caracteres corretos ficam verdes, erros ficam vermelhos</li>
        <li>Seu PPM e precisão são calculados em tempo real</li>
        <li>Supere seu recorde pessoal e suba no ranking</li>
      </ul>
      <p class="text-sand-500">Pratique diariamente para melhorar sua velocidade. A média é 40 PPM, enquanto profissionais alcançam 80+ PPM.</p>
    </article>
  </div>
  <PwaInstallPrompt client:only="react" />
</Layout>
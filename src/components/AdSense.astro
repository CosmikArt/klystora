---
interface Props {
  slot?: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  class?: string;
}

const { slot = 'default', format = 'auto', class: className = '' } = Astro.props;

// Only show ads in production
const isDev = import.meta.env.DEV;
---

{!isDev && (
  <div class={`ad-container ${className}`}>
    <ins 
      class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive="true"
    ></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}

<style>
  .ad-container {
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ad-container:empty {
    display: none;
  }
</style>
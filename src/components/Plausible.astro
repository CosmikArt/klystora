---
// Plausible Analytics - privacy-first, no cookies, GDPR compliant
---

<script 
  defer 
  data-domain="klystora.com" 
  src="https://plausible.io/js/script.js"
></script>

<!-- Also track outbound links, file downloads, and custom events -->
<script 
  defer 
  data-domain="klystora.com" 
  data-api="https://plausible.io/api/event"
  src="https://plausible.io/js/script.outbound-links.file-downloads.tagged-events.js"
></script>

<!-- Helper for manual event tracking -->
<script>
  window.trackEvent = function(eventName, props = {}) {
    if (window.plausible) {
      plausible(eventName, { props });
    }
  };
</script>

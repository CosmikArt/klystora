---
import '../styles/global.css';
import { getLocaleFromPath, getMessages, getHomeUrl, getGameUrl, type Locale, locales, localeNames, ogLocales } from '../lib/i18n';
import Plausible from '../components/Plausible.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { 
  title = 'Klystora — Word games. New every day.',
  description = 'Eight daily word games in 27 languages. No signup, no pop-up ads. Play instantly.',
  ogImage = '/og/default.jpg'
} = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname) as Locale;
const messages = getMessages(locale);
const ogLocale = ogLocales[locale] || 'en_US';

// Build language switcher URLs
const pathWithoutLocale = Astro.url.pathname.replace(/^\/[a-z]{2}\//, '/').replace(/^\/[a-z]{2}$/, '/');
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6845BC" />
    
    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Klystora" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Canonical + Hreflang -->
    <link rel="canonical" href={`https://klystora.com${currentPath}`} />
    {locales.map(loc => {
      const locPath = loc === 'en' ? pathWithoutLocale : `/${loc}${pathWithoutLocale}`;
      return <link rel="alternate" hreflang={loc} href={`https://klystora.com${locPath}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`https://klystora.com${pathWithoutLocale}`} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
    
    <!-- Plausible Analytics -->
    <Plausible />
    
    <!-- Schema.org Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Klystora",
        "url": "https://klystora.com",
        "logo": "https://klystora.com/favicon.svg"
      }
    </script>
  </head>
  <body class="min-h-screen bg-sand-50 text-sand-900 dark:bg-sand-950 dark:text-sand-100 transition-colors">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-sand-50/80 dark:bg-sand-950/80 backdrop-blur-md border-b border-sand-200 dark:border-sand-800 transition-colors">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href={getHomeUrl(locale)} class="flex items-center gap-2">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 2L26 14L14 26L2 14L14 2Z" fill="url(#kly)" />
            <defs>
              <linearGradient id="kly" x1="2" y1="2" x2="26" y2="26">
                <stop stop-color="#A484F0" />
                <stop offset="1" stop-color="#6845BC" />
              </linearGradient>
            </defs>
          </svg>
          <span class="font-semibold text-lg tracking-tight">Klystora</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-6">
          <a href={getHomeUrl(locale)} class="text-sm font-medium text-sand-600 dark:text-sand-400 hover:text-violet-600 dark:hover:text-violet-400 transition">{messages.nav.games}</a>
          <a href={locale === 'en' ? '/blog' : `/${locale}/blog`} class="text-sm font-medium text-sand-600 dark:text-sand-400 hover:text-violet-600 dark:hover:text-violet-400 transition">{messages.nav.blog}</a>
          <a href={locale === 'en' ? '/about' : `/${locale}/about`} class="text-sm font-medium text-sand-600 dark:text-sand-400 hover:text-violet-600 dark:hover:text-violet-400 transition">{messages.nav.about}</a>
        </nav>
        
        <div class="flex items-center gap-3">
          <!-- Theme Toggle -->
          <button id="theme-toggle" class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400 transition" aria-label="Toggle dark mode">
            <svg id="sun-icon" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            <svg id="moon-icon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
          </button>
          <!-- Language Selector -->
          <div class="relative group">
            <button class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400 transition flex items-center gap-1">
              {localeNames[locale]}
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute right-0 top-full mt-1 w-48 bg-white dark:bg-sand-900 rounded-lg shadow-lg border border-sand-200 dark:border-sand-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 max-h-64 overflow-y-auto">
              {locales.map(loc => {
                const locPath = loc === 'en' ? pathWithoutLocale : `/${loc}${pathWithoutLocale}`;
                return (
                  <a 
                    href={locPath}
                    class={`block px-4 py-2 text-sm hover:bg-sand-100 dark:hover:bg-sand-800 transition ${loc === locale ? 'text-violet-600 dark:text-violet-400 font-medium bg-sand-100 dark:bg-sand-800' : 'text-sand-700 dark:text-sand-300'}`}
                  >
                    {localeNames[loc]}
                  </a>
                );
              })}
            </div>
          </div>
          <a href={getGameUrl('dailyWord', locale)} class="bg-violet-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-violet-700 transition">
            {messages.playNow}
          </a>
        </div>
      </div>
    </header>
    
    <main>
      <slot />
    </main>
    
    <!-- Footer -->
    <footer class="border-t border-sand-200 dark:border-sand-800 mt-20 transition-colors">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <h4 class="font-semibold text-sm mb-4">{messages.footer.games}</h4>
            <ul class="space-y-2">
              <li><a href={getGameUrl('dailyWord', locale)} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.games.dailyWord.name}</a></li>
              <li><a href={getGameUrl('crossword', locale)} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.games.crossword.name}</a></li>
              <li><a href={getGameUrl('wordSearch', locale)} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.games.wordSearch.name}</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-sm mb-4">{messages.footer.company}</h4>
            <ul class="space-y-2">
              <li><a href={locale === 'en' ? '/about' : `/${locale}/about`} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.nav.about}</a></li>
              <li><a href={locale === 'en' ? '/blog' : `/${locale}/blog`} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.nav.blog}</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-sm mb-4">{messages.footer.legal}</h4>
            <ul class="space-y-2">
              <li><a href={locale === 'en' ? '/privacy' : `/${locale}/privacy`} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.footer.privacy}</a></li>
              <li><a href={locale === 'en' ? '/terms' : `/${locale}/terms`} class="text-sm text-sand-500 hover:text-violet-600 dark:hover:text-violet-400">{messages.footer.terms}</a></li>
            </ul>
          </div>
          <div>
            <p class="text-sm text-sand-500">© 2026 Klystora</p>
            <p class="text-xs text-sand-400 mt-1">Ore Data México S.A.</p>
          </div>
        </div>
      </div>
    </footer>
    <script>
      // Theme toggle
      (function() {
        const html = document.documentElement;
        const toggle = document.getElementById('theme-toggle');
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        if (saved === 'dark' || (!saved && prefersDark)) {
          html.classList.add('dark');
        }
        
        if (toggle) {
          toggle.addEventListener('click', () => {
            html.classList.toggle('dark');
            localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
          });
        }
      })();
      
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
